generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentType {
  MOVIE
  SONG
  WEB_SERIES
  DUBBED_MOVIE
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum UserRole {
  SUPER_ADMIN
  EDITOR
  VIEWER
}

enum HomepageSectionKey {
  HERO
  TRENDING
  TOP_TAMIL_MOVIES
  TOP_DUBBED
  FEATURED
}

enum CreditRole {
  ACTOR
  DIRECTOR
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  UNPUBLISH
  BULK_DELETE
  BULK_STATUS
  LOGIN
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  emailVerified DateTime?
  image        String?
  passwordHash String?
  role         UserRole  @default(EDITOR)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  accounts     Account[]
  sessions     Session[]
  auditLogs    AuditLog[]
  mediaAssets  MediaAsset[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Genre {
  id       String         @id @default(cuid())
  name     String         @unique
  slug     String         @unique
  contents ContentGenre[]
}

model Person {
  id          String        @id @default(cuid())
  name        String
  tamilName   String?
  slug        String        @unique
  imageUrl    String?
  directed    Content[]     @relation("ContentDirector")
  castCredits ContentCast[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Platform {
  id       String            @id @default(cuid())
  name     String            @unique
  slug     String            @unique
  logoUrl  String?
  contents ContentPlatform[]
}

model Content {
  id              String            @id @default(cuid())
  slug            String            @unique
  title           String
  tamilTitle      String?
  description     String            @db.Text
  year            Int
  type            ContentType
  genre           String
  language        String            @default("Tamil")
  quality         String?
  featured        Boolean           @default(false)
  trending        Boolean           @default(false)
  accent          String            @default("#00c853")
  status          ContentStatus     @default(DRAFT)
  publishedAt     DateTime?
  deletedAt       DateTime?
  posterUrl       String?
  backdropUrl     String?
  trailerUrl      String?
  country         String?
  seriesSeasons   Int?
  seriesEpisodes  Int?
  seriesStatus    String?
  originalLanguage String?
  dubbedLanguage  String?
  sourceTitle     String?
  rating          Float?
  ratingCount     Int?
  runtimeMinutes  Int?
  directorId      String?
  metaTitle       String?
  metaDescription String?           @db.Text
  keywords        String[]          @default([])
  canonicalUrl    String?
  ogImageUrl      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  director        Person?           @relation("ContentDirector", fields: [directorId], references: [id], onDelete: SetNull)
  genres          ContentGenre[]
  cast            ContentCast[]
  platforms       ContentPlatform[]
  homepageSlots   HomepageSlot[]
  watchlistItems  WatchlistItem[]
  recentlyViewed  RecentlyViewed[]

  @@index([year])
  @@index([type])
  @@index([trending])
  @@index([status, type])
  @@index([deletedAt])
}

model ContentGenre {
  contentId String
  genreId   String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  genre     Genre   @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([contentId, genreId])
}

model ContentCast {
  id        String     @id @default(cuid())
  contentId String
  personId  String
  role      CreditRole @default(ACTOR)
  character String?
  sortOrder Int        @default(0)
  content   Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  person    Person     @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([contentId])
}

model ContentPlatform {
  id         String   @id @default(cuid())
  contentId  String
  platformId String
  url        String
  content    Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  platform   Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@unique([contentId, platformId])
}

model MediaAsset {
  id           String   @id @default(cuid())
  key          String   @unique
  url          String
  mimeType     String
  sizeBytes    Int
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
}

model HomepageSection {
  id       String             @id @default(cuid())
  key      HomepageSectionKey @unique
  title    String
  active   Boolean            @default(true)
  slots    HomepageSlot[]
  updatedAt DateTime          @updatedAt
}

model HomepageSlot {
  id            String          @id @default(cuid())
  sectionId     String
  contentId     String
  position      Int
  active        Boolean         @default(true)
  overrideTitle String?
  overrideImage String?
  section       HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  content       Content         @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([sectionId, contentId])
  @@index([sectionId, position])
}

model HeroBanner {
  id                String    @id @default(cuid())
  title             String
  subtitle          String?
  ctaLabel          String?
  ctaHref           String?
  backgroundImageUrl String?
  active            Boolean   @default(true)
  startsAt          DateTime?
  endsAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model EndUser {
  id             String           @id @default(cuid())
  email          String?          @unique
  name           String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  watchlist      WatchlistItem[]
  recentlyViewed RecentlyViewed[]
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  createdAt DateTime @default(now())
  user      EndUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  viewedAt  DateTime @default(now())
  user      EndUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([userId, viewedAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  action     AuditAction
  entity     String
  entityId   String?
  metadata   Json?
  createdAt  DateTime    @default(now())
  actor      User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorId])
}
