generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole     @default(USER)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  accounts      Account[]
  auditLogs     AuditLog[]
  mediaAssets   MediaAsset[]
  ratings       UserRating[]
  recentlyViewed RecentlyViewed[]
  sessions      Session[]
  watchlistItems WatchlistItem[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Genre {
  id       String         @id @default(cuid())
  name     String         @unique
  slug     String         @unique
  contents ContentGenre[]
}

model Person {
  id          String        @id @default(cuid())
  name        String
  tamilName   String?
  slug        String        @unique
  imageUrl    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  directed    Content[]     @relation("ContentDirector")
  castCredits ContentCast[]
}

model Platform {
  id       String            @id @default(cuid())
  name     String            @unique
  slug     String            @unique
  logoUrl  String?
  contents ContentPlatform[]
}

model Content {
  id               String            @id @default(cuid())
  slug             String            @unique
  title            String
  tamilTitle       String?
  description      String
  year             Int
  type             ContentType
  genre            String
  language         String            @default("Tamil")
  quality          String?
  featured         Boolean           @default(false)
  trending         Boolean           @default(false)
  accent           String            @default("#00c853")
  status           ContentStatus     @default(DRAFT)
  publishedAt      DateTime?
  deletedAt        DateTime?
  posterUrl        String?
  trailerUrl       String?
  rating           Float?
  ratingCount      Int?
  runtimeMinutes   Int?
  directorId       String?
  metaTitle        String?
  metaDescription  String?
  keywords         String[]          @default([])
  canonicalUrl     String?
  ogImageUrl       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  backdropUrl      String?
  country          String?
  dubbedLanguage   String?
  originalLanguage String?
  seriesEpisodes   Int?
  seriesSeasons    Int?
  seriesStatus     String?
  sourceTitle      String?
  director         Person?           @relation("ContentDirector", fields: [directorId], references: [id])
  cast             ContentCast[]
  genres           ContentGenre[]
  platforms        ContentPlatform[]
  homepageSlots    HomepageSlot[]
  recentlyViewed   RecentlyViewed[]
  ratings          UserRating[]
  watchlistItems   WatchlistItem[]

  @@index([year])
  @@index([type])
  @@index([trending])
  @@index([status, type])
  @@index([deletedAt])
}

model ContentGenre {
  contentId String
  genreId   String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  genre     Genre   @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([contentId, genreId])
}

model ContentCast {
  id        String     @id @default(cuid())
  contentId String
  personId  String
  role      CreditRole @default(ACTOR)
  character String?
  sortOrder Int        @default(0)
  content   Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  person    Person     @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([contentId])
}

model ContentPlatform {
  id         String   @id @default(cuid())
  contentId  String
  platformId String
  url        String
  content    Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  platform   Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@unique([contentId, platformId])
}

model MediaAsset {
  id           String   @id @default(cuid())
  key          String   @unique
  url          String
  mimeType     String
  sizeBytes    Int
  uploadedById String?
  createdAt    DateTime @default(now())
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
}

model HomepageSection {
  id        String             @id @default(cuid())
  key       HomepageSectionKey @unique
  title     String
  active    Boolean            @default(true)
  updatedAt DateTime           @updatedAt
  slots     HomepageSlot[]
}

model HomepageSlot {
  id            String          @id @default(cuid())
  sectionId     String
  contentId     String
  position      Int
  active        Boolean         @default(true)
  overrideTitle String?
  overrideImage String?
  content       Content         @relation(fields: [contentId], references: [id], onDelete: Cascade)
  section       HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, contentId])
  @@index([sectionId, position])
}

model HeroBanner {
  id                 String    @id @default(cuid())
  title              String
  subtitle           String?
  ctaLabel           String?
  ctaHref            String?
  backgroundImageUrl String?
  active             Boolean   @default(true)
  startsAt           DateTime?
  endsAt             DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  createdAt DateTime @default(now())
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  viewedAt  DateTime @default(now())
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId, viewedAt])
}

model UserRating {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  score     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([contentId])
  @@index([userId, updatedAt])
}

model AuditLog {
  id        String      @id @default(cuid())
  actorId   String?
  action    AuditAction
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime    @default(now())
  actor     User?       @relation(fields: [actorId], references: [id])

  @@index([createdAt])
  @@index([actorId])
}

enum ContentType {
  MOVIE
  SONG
  WEB_SERIES
  DUBBED_MOVIE
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum UserRole {
  ADMIN
  EDITOR
  USER
}

enum HomepageSectionKey {
  HERO
  TRENDING
  TOP_TAMIL_MOVIES
  TOP_DUBBED
  FEATURED
}

enum CreditRole {
  ACTOR
  DIRECTOR
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  UNPUBLISH
  BULK_DELETE
  BULK_STATUS
  LOGIN
}
